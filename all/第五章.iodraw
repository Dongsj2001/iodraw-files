        <mxCell id="fVpT6Kow-ts5sUFJ23zf-63" value="构建当前轮之前的对话历史&lt;br&gt;H&lt;sub&gt;t&lt;/sub&gt; = {(q&lt;sub&gt;1&lt;/sub&gt;,a&lt;sub&gt;1&lt;/sub&gt;),(q&lt;sub&gt;2&lt;/sub&gt;,a&lt;sub&gt;2&lt;/sub&gt;),...,(q&lt;sub&gt;(t-1)&lt;/sub&gt;,a&lt;sub&gt;(t-1)&lt;/sub&gt;)}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15" parent="1" vertex="1">
