        <mxCell id="fVpT6Kow-ts5sUFJ23zf-62" value="输入初始信息&lt;br&gt;医学影像特征 v&lt;br&gt;候选疾病集合 D&lt;sub&gt;cand&lt;/sub&gt;&lt;br&gt;初始症状集合 S&lt;sub&gt;ask&lt;/sub&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15" parent="1" vertex="1">
